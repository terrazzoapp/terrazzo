{
  "name": "@terrazzo/monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:apps": "turbo run build:app",
    "changeset": "changeset",
    "inject-license": "node scripts/inject-license.js",
    "dev": "pnpm run -r --parallel --if-present dev",
    "lint": "turbo run lint",
    "lint:spell": "cspell lint \"packages/**\" \"www/**\"",
    "fmt": "turbo run fmt",
    "fmt:check": "turbo run fmt:check",
    "test": "turbo run test",
    "prepublishOnly": "pnpm run build",
    "version": "pnpm run build && changeset version"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.31.0",
    "@types/node": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "cspell": "^9.8.0",
    "execa": "^9.6.1",
    "merge-anything": "^5.1.7",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "playwright": "catalog:",
    "rolldown": "1.1.4",
    "rolldown-plugin-dts": "^0.27.1",
    "strip-ansi": "^7.2.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "turbo": "^2.10.4",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.10.0"
}
