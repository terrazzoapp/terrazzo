{
  "name": "@terrazzo/token-types",
  "version": "2.3.0",
  "description": "Shared dependency-free TypeScript types for DTCG design tokens.",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Drew Powers",
    "email": "drew@pow.rs"
  },
  "keywords": [
    "design tokens",
    "dtcg",
    "w3c",
    "design system",
    "typescript",
    "style tokens",
    "style system",
    "types"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/terrazzoapp/terrazzo.git",
    "directory": "./packages/token-types/"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rolldown -c && attw --profile esm-only --pack .",
    "dev": "rolldown -w -c",
    "format": "biome check --fix --unsafe .",
    "lint": "pnpm --filter @terrazzo/token-types run \"/^lint:(js|ts)/\"",
    "lint:js": "biome check .",
    "lint:ts": "tsc --noEmit"
  }
}
