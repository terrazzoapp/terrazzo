{
  "name": "@terrazzo/token-types",
  "version": "2.4.0",
  "description": "Shared dependency-free TypeScript types for DTCG design tokens.",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Drew Powers",
    "email": "drew@pow.rs"
  },
  "keywords": [
    "design tokens",
    "dtcg",
    "w3c",
    "design system",
    "typescript",
    "style tokens",
    "style system",
    "types"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/terrazzoapp/terrazzo.git",
    "directory": "./packages/token-types/"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json && attw --profile esm-only --pack .",
    "dev": "tsc -b tsconfig.build.json -w",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --quiet && oxfmt --check && tsc --noEmit"
  }
}
