{
  "$schema": "https://www.designtokens.org/schemas/2025.10/resolver.json",
  "version": "2025.10",
  "resolutionOrder": [
    { "$ref": "#/sets/a" },
    { "$ref": "#/sets/b" },
    { "$ref": "#/modifiers/theme" },
    { "$ref": "#/modifiers/contrast" }
  ],
  "sets": {
    "a": {
      "sources": [{ "weight": { "normal": { "$type": "fontWeight", "$value": 400 } } }]
    },
    "b": {
      "sources": [{ "weight": { "bold": { "$type": "fontWeight", "$value": 700 } } }]
    }
  },
  "modifiers": {
    "theme": {
      "name": "a",
      "contexts": {
        "light": [],
        "dark": [{ "$ref": "./theme-dark.json" }]
      }
    },
    "contrast": {
      "name": "a",
      "contexts": {
        "default": [{ "$ref": "./contrast-default.json" }],
        "slim": [{ "$ref": "./contrast-slim.json" }]
      }
    }
  }
}
