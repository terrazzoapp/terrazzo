{
  "name": "@terrazzo/tiles",
  "version": "0.2.0",
  "description": "Terrazzo’s component library",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Drew Powers",
    "email": "drew@pow.rs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/terrazzoapp/terrazzo.git",
    "directory": "./packages/tiles/"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "rollup -c rollup.config.js && size-limit",
    "dev": "pnpm run build && chokidar \"src/**/*\" -c \"rollup -c rollup.config.js\"",
    "fmt": "oxfmt && pnpm --filter @terrazzo/tiles run fmt:css",
    "fmt:check": "oxfmt --check",
    "fmt:css": "stylelint --fix \"src/**/*.css\"",
    "lint": "oxlint --quiet && oxfmt --check && pnpm --filter @terrazzo/tiles run lint:css",
    "lint:css": "stylelint \"src/**/*.css\"",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@terrazzo/fonts": "workspace:^",
    "@terrazzo/icons": "workspace:^",
    "@terrazzo/tokens": "workspace:^",
    "@terrazzo/use-color": "workspace:^",
    "@use-gesture/react": "^10.3.1",
    "clsx": "^2.1.1",
    "colorjs.io": "catalog:",
    "shiki": "^3.23.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "chokidar-cli": "^3.0.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rollup": "^4.62.2",
    "rollup-plugin-import-css": "^4.2.1",
    "size-limit": "^12.1.0",
    "vitest-axe": "^0.1.0"
  }
}
