{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "color": {
    "primary": {
      "$type": "color",
      "$value": { "colorSpace": "srgb", "components": [0, 0.5, 0] },
      "$description": "Brand2 primary (green)"
    },
    "secondary": {
      "$type": "color",
      "$value": { "colorSpace": "srgb", "components": [1, 0.5, 0] },
      "$description": "Brand2 secondary (orange)"
    }
  },
  "input-amount": {
    "$extends": "{input}",
    "field": {
      "width": {
        "$value": {
          "value": 15,
          "unit": "px"
        },
        "$description": "A description with Jack..."
      }
    }
  }
}
