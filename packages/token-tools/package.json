{
  "name": "@terrazzo/token-tools",
  "version": "2.4.0",
  "description": "Various utilities for token types",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Drew Powers",
    "email": "drew@pow.rs"
  },
  "keywords": [
    "design tokens",
    "dtcg",
    "cli",
    "w3c",
    "design system",
    "typescript",
    "sass",
    "css",
    "style tokens",
    "style system",
    "linting",
    "lint"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/terrazzoapp/terrazzo.git",
    "directory": "./packages/token-tools/"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./css": "./dist/css/index.js",
    "./js": "./dist/js/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json && attw --profile esm-only --pack .",
    "dev": "tsc -b tsconfig.build.json -w",
    "format": "biome check --fix --unsafe .",
    "lint": "pnpm --filter @terrazzo/token-tools run \"/^lint:(js|ts)/\"",
    "lint:js": "biome check .",
    "lint:ts": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@humanwhocodes/momoa": "catalog:",
    "@terrazzo/token-types": "workspace:^",
    "colorjs.io": "catalog:",
    "wildcard-match": "^5.1.4"
  }
}
