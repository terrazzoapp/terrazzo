{
  "$schema": "https://www.designtokens.org/schemas/2025.10/resolver.json",
  "version": "2025.10",
  "resolutionOrder": [{ "$ref": "#/sets/base" }],
  "sets": {
    "base": {
      "sources": [
        {
          "color": {
            "accent": {
              "$type": "color",
              "bg": { "$value": "#2e5bff" },
              "bg-hover": { "$value": "#1f48e0" },
              "fg": { "$value": "#ffffff" }
            }
          },
          "number": {
            "line-height": {
              "$type": "number",
              "loose": { "$value": 1.75 },
              "tight": { "$value": 1.15 }
            }
          }
        }
      ]
    }
  }
}
