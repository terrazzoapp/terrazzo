{
  "name": "@terrazzo/plugin-css-in-js",
  "version": "2.4.0",
  "description": "Use CSS Vars in clientside JS. Compatible with Linaria, StyleX, Vanilla Extract, Styled Components, and most CSS-in-JS libraries.",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Drew Powers",
    "email": "drew@pow.rs"
  },
  "keywords": [
    "design tokens",
    "design system",
    "dtcg",
    "w3c",
    "css",
    "styled components",
    "vanilla-extract",
    "stylex",
    "linearia",
    "emotion",
    "react",
    "vue",
    "ts",
    "typescript"
  ],
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "homepage": "https://terrazzo.app/docs/integrations/js",
  "repository": {
    "type": "git",
    "url": "https://github.com/terrazzoapp/terrazzo.git",
    "directory": "./packages/plugin-js/"
  },
  "scripts": {
    "build": "rolldown -c && attw --profile esm-only --pack .",
    "dev": "rolldown -w -c",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --quiet && oxfmt --check && tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@terrazzo/cli": "workspace:^",
    "@terrazzo/parser": "workspace:^",
    "@terrazzo/plugin-css": "workspace:^"
  },
  "dependencies": {
    "scule": "^1.3.0"
  },
  "devDependencies": {
    "@terrazzo/cli": "workspace:^",
    "@terrazzo/parser": "workspace:^",
    "@terrazzo/plugin-css": "workspace:^",
    "dtcg-examples": "catalog:"
  }
}
