{
  "color": {
    "$type": "color",
    "bg-primary_hover": {
      "$value": { "colorSpace": "srgb", "components": [0.2, 0.4, 0.8], "alpha": 1 },
      "$extensions": {
        "mode": {
          "light": { "colorSpace": "srgb", "components": [0.2, 0.4, 0.8], "alpha": 1 },
          "dark": { "colorSpace": "srgb", "components": [0.3, 0.5, 0.9], "alpha": 1 }
        }
      }
    },
    "bg-primary_active": {
      "$value": { "colorSpace": "srgb", "components": [0.1, 0.3, 0.7], "alpha": 1 },
      "$extensions": {
        "mode": {
          "light": { "colorSpace": "srgb", "components": [0.1, 0.3, 0.7], "alpha": 1 },
          "dark": { "colorSpace": "srgb", "components": [0.2, 0.4, 0.8], "alpha": 1 }
        }
      }
    }
  },
  "typography": {
    "xs": {
      "$type": "dimension",
      "$value": { "value": 12, "unit": "px" },
      "$extensions": {
        "mode": {
          "light": { "value": 12, "unit": "px" },
          "dark": { "value": 12, "unit": "px" }
        }
      }
    },
    "xs--line-height": {
      "$type": "dimension",
      "$value": { "value": 16, "unit": "px" },
      "$extensions": {
        "mode": {
          "light": { "value": 16, "unit": "px" },
          "dark": { "value": 16, "unit": "px" }
        }
      }
    },
    "fontSmall": {
      "$type": "dimension",
      "$value": { "value": 14, "unit": "px" },
      "$extensions": {
        "mode": {
          "light": { "value": 14, "unit": "px" },
          "dark": { "value": 14, "unit": "px" }
        }
      }
    }
  }
}
