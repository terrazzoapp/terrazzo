{
  "name": "@terrazzo/json-schema-tools",
  "version": "0.2.1",
  "description": "Bundle JSON Schema documents and tools for resolving $refs.",
  "type": "module",
  "keywords": [
    "json",
    "json schema",
    "pointer",
    "ref",
    "rfc",
    "6901"
  ],
  "author": {
    "name": "Drew Powers",
    "email": "drew@pow.rs"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": "./*"
  },
  "homepage": "https://terrazzo.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/terrazzoapp/terrazzo.git",
    "directory": "./packages/json-schema-tools/"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc -b tsconfig.build.json && attw --profile esm-only --pack .",
    "dev": "tsc -b tsconfig.build.json -w",
    "bench": "vitest bench",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --quiet && oxfmt --check && tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@humanwhocodes/momoa": "^3.0.0",
    "yaml-to-momoa": "catalog:"
  },
  "peerDependenciesMeta": {
    "yaml-to-momoa": {
      "optional": true
    }
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^11.9.3",
    "@humanwhocodes/momoa": "catalog:",
    "yaml-to-momoa": "catalog:"
  }
}
