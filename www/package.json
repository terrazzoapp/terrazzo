    "@terrazzo/use-color": "workspace:^",
    "algoliasearch": "^5.55.2",
    "nanoid": "^5.1.16",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-instantsearch": "^7.39.0",
    "shiki": "^1.29.2"
  },
  "devDependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/react": "4.4.2",
    "@astrojs/sitemap": "^3.7.3",
